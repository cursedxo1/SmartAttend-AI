{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (teacher or student)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "displayName": { "type": "string" },
        "studentId": { "type": "string" },
        "parentEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code", "teacherId"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Link between student and course",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      }
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Daily attendance for a student in a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "FaceDescriptor": {
      "title": "Face Descriptor",
      "description": "Face embeddings for recognition",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "descriptors": { "type": "array", "items": { "type": "number" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course information"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Course enrollment records"
    },
    "/attendanceRecords/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Attendance history"
    },
    "/faceDescriptors/{descriptorId}": {
      "schema": "FaceDescriptor",
      "description": "Biometric face data"
    }
  }
}
